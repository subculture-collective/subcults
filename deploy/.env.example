# ============================================================================
# Subcults deployment environment template (reverse-proxy setup)
# ============================================================================
# Copy to deploy/.env and fill with production/staging values.
# This profile assumes:
# - external Caddy reverse proxy in ~/projects/caddy on Docker network 'web'
# - no mandatory monitoring/observability stack yet
#
# cp deploy/.env.example deploy/.env

# Core runtime
SUBCULT_ENV=production
METRICS_PORT=9090

# Public origins for browser clients (comma-separated, no wildcards)
# Example: https://subcults.example.com
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Database (required)
DATABASE_URL=postgres://user:password@host:5432/subcults?sslmode=require

# Auth (required)
# Set either JWT_SECRET, or JWT_SECRET_CURRENT (recommended with optional previous key)
JWT_SECRET=
JWT_SECRET_CURRENT=
JWT_SECRET_PREVIOUS=

# LiveKit (required)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Stripe (required)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ONBOARDING_RETURN_URL=
STRIPE_ONBOARDING_REFRESH_URL=
STRIPE_APPLICATION_FEE_PERCENT=5.0

# Map tiles + ingestion (required)
MAPTILER_API_KEY=
JETSTREAM_URL=wss://jetstream1.us-east.bsky.network/subscribe

# Optional media storage (R2)
# Leave all blank to disable media storage integration.
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_MAX_UPLOAD_SIZE_MB=15

# Optional redis/rate limiting internals
REDIS_URL=
INTERNAL_SERVICE_TOKEN=
INTERNAL_AUTH_TOKEN=

# Feature flags (safe defaults)
RANK_TRUST_ENABLED=false
CANARY_ENABLED=false
CANARY_TRAFFIC_PERCENT=5.0
CANARY_ERROR_THRESHOLD=1.0
CANARY_LATENCY_THRESHOLD=2.0
CANARY_AUTO_ROLLBACK=true
CANARY_MONITORING_WINDOW=300
CANARY_VERSION=canary

# Tracing/observability disabled for now
TRACING_ENABLED=false
TRACING_EXPORTER_TYPE=otlp-http
TRACING_OTLP_ENDPOINT=
TRACING_SAMPLE_RATE=0.1
TRACING_INSECURE=false

# Frontend build-time Vite variables
# Keep /api when Caddy routes API on same domain.
VITE_API_URL=/api
# Set to a public key value for map rendering in frontend bundle.
VITE_MAPTILER_API_KEY=
VITE_R2_CDN_URL=
VITE_VAPID_PUBLIC_KEY=
VITE_LIVEKIT_WS_URL=
VITE_APP_VERSION=dev
